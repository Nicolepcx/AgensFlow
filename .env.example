# AgensFlow — required environment variables.
# Copy this file to `.env` (which is gitignored) and fill in the values.

# ---- Always required ----
# OpenRouter is the unified API for all LLM calls (agents + judges).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ---- Required when web search is in the activation plan ----
# Used by `web_search_exa` skill. Skip if you never invoke it.
# Get a key at https://exa.ai
EXA_API_KEY=

# Used by `web_search_tavily` skill. Skip if you never invoke it.
# Get a key at https://tavily.com
TAVILY_API_KEY=

# ---- Optional: OpenRouter attribution headers ----
# Surface your app name + URL in OpenRouter's per-app dashboards.
# Useful for tracking experiment spend separately. Leave empty for default.
OPENROUTER_APP_NAME=
OPENROUTER_APP_URL=
